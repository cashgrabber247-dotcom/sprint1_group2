    )
    fig_cm_live.update_layout(
        title=f"Confusion Matrix — Satisfaction Prediction (refresh #{n_intervals})",
        paper_bgcolor=BG,
        plot_bgcolor=BG,
        font=dict(color=TEXT),
        margin=dict(t=60, b=40, l=40, r=40)
    )
    return fig_cm_live


